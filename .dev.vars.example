# Rename this file from .dev.vars.example to .dev.vars and paste in your credentials

ENVIRONMENT=development

# The email address to receive contact form messages (use your Gmail)
TO_EMAIL=you@gmail.com

# Optional alias for TO_EMAIL for backward compatibility
EMAIL=you@gmail.com

# Preferred provider: Resend
RESEND_API_KEY=PASTE_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=Portfolio <noreply@yourdomain.com>

# Fallback provider: AWS SES
# The email address to send emails from (must be verified in AWS SES)
FROM_EMAIL=portfolio-site@website.com

# Credentials from your AWS account
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_KEY

# This is a random string used for the session cookie for saving the preferred theme
SESSION_SECRET=KEEP_IT_SECRET_KEEP_IT_SAFE
